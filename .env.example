# Versions
TRAEFIK_VERSION=v3.6.5
CROWDSEC_VERSION=v1.7.6
CROWDSEC_BOUNCER_PLUGIN_VERSION=v1.4.7
CROWDSEC_MANAGER_VERSION=0.0.5

# Traefik Dashboard Host
TRAEFIK_DASHBOARD_HOST=traefik.localhost

# Wildcard TLS certificate domain (e.g. example.com → generates *.example.com)
WILDCARD_DOMAIN=

# Let's Encrypt
LETSENCRYPT_EMAIL=

# Cloudflare proxy IP ranges — used to trust X-Forwarded-For headers (single line, no spaces)
TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22,2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2a06:98c0::/29,2c0f:f248::/32

# Cloudflare DNS API token (required only when using le-cloudflare cert resolver)
CLOUDFLARE_DNS_API_TOKEN=

# IP Allowlists are defined in .docker/traefik/conf/middlewares.yml (copy from middlewares.yml.example)

# CrowdSec
CROWDSEC_DASHBOARD_HOST=crowdsec.localhost
CROWDSEC_MANAGER_API_KEY=
CROWDSEC_MANAGER_TZ=Europe/Istanbul

CROWDSEC_TRAEFIK_BOUNCER_API_KEY=
# On bouncer error — allow: let traffic through (less secure) | ban: block traffic (more secure)
CROWDSEC_ON_ERROR=ban
# WARNING: Must match the docker group GID on the host, otherwise CrowdSec cannot read
# container logs and will silently fail to detect attacks.
# Run: getent group docker  →  e.g. "docker:x:998:deployer" means GID=998
CROWDSEC_GID=
CROWDSEC_HUB_UPGRADE_DISABLE=false
