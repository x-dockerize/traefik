http:
  middlewares:
    # Trusted IPs: office, VPN, and server/worker IPs
    # Used for: routes behind Cloudflare proxy (orange cloud ON)
    trusted:
      ipAllowList:
        sourceRange:
          # --- Tailscale / Headscale IPs ---
          - 100.64.0.0/10    # Headscale default CGNAT range
          - 172.18.0.1/32    # Docker bridge gateway (Tailscale traffic is NAT'd by Docker)

          # --- Office IPs ---
          # - 1.2.3.4/32  # Istanbul HQ
          # - 5.6.7.8/32  # Ankara branch

          # --- VPN IPs ---
          # - 9.10.11.12/32  # VPN server 1

          # --- Server / Worker IPs ---
          # - 13.14.15.16/32  # API worker 1
        ipStrategy:
          depth: 1  # Cloudflare proxy ON (orange cloud)

    # Trusted IPs (direct): same allowlist but for routes bypassing Cloudflare proxy (grey cloud)
    # Used for: subdomains where Cloudflare proxy is OFF
    trusted-direct:
      ipAllowList:
        sourceRange:
          # --- Tailscale / Headscale IPs ---
          - 100.64.0.0/10    # Headscale default CGNAT range
          - 172.18.0.1/32    # Docker bridge gateway (Tailscale traffic is NAT'd by Docker)

          # --- Office IPs ---
          # - 1.2.3.4/32  # Istanbul HQ
          # - 5.6.7.8/32  # Ankara branch

          # --- VPN IPs ---
          # - 9.10.11.12/32  # VPN server 1

          # --- Server / Worker IPs ---
          # - 13.14.15.16/32  # API worker 1
        ipStrategy:
          depth: 0  # Cloudflare proxy OFF (grey cloud)

    # Internal IPs: Headscale/Tailscale mesh network
    # Used for: service-to-service communication via .internal. domains
    internal:
      ipAllowList:
        sourceRange:
          - 100.64.0.0/10    # Headscale default CGNAT range
          - 172.18.0.1/32    # Docker bridge gateway (Tailscale traffic is NAT'd by Docker)
        ipStrategy:
          depth: 0  # Headscale traffic is direct (not proxied through Cloudflare)
